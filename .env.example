ENVIRONMENT=local
LOG_LEVEL=INFO

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west2
GCS_BRONZE_BUCKET=football-intelligence-bronze
GCS_SILVER_BUCKET=football-intelligence-silver
GCS_GOLD_BUCKET=football-intelligence-gold
BIGQUERY_DATASET_BRONZE=football_bronze
BIGQUERY_DATASET_SILVER=football_silver
BIGQUERY_DATASET_GOLD=football_gold
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

STATSBOMB_OPEN_DATA_BASE_URL=https://raw.githubusercontent.com/statsbomb/open-data/master/data
STATSBOMB_LOCAL_DATA_DIR=
STATSBOMB_BRONZE_OPEN_DATA_DIR=./data/bronze/statsbomb/open-data
STATSBOMB_COLLECTIONS=competitions,matches,events,lineups,three-sixty
STATSBOMB_COMPETITION_IDS=
STATSBOMB_SEASON_IDS=
STATSBOMB_MATCH_IDS=
LOCAL_BRONZE_DIR=./data/bronze
LOCAL_SILVER_DIR=./data/silver
TRANSFERMARKT_BASE_URL=https://www.transfermarkt.com
TRANSFERMARKT_USER_AGENT=football-intelligence-platform/0.1 contact@example.com
TRANSFERMARKT_REQUEST_DELAY_SECONDS=2
TRANSFERMARKT_SQUAD_URLS=
TRANSFERMARKT_TRANSFER_URLS=

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false

API_HOST=0.0.0.0
API_PORT=8000
STREAMLIT_SERVER_PORT=8501
